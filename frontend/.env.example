# Public URL used inside patient QR codes (must be reachable from mobile cameras).
# Dev example — use your PC's LAN IP so iPhone/Android on the same Wi‑Fi can open the page:
# VITE_PUBLIC_APP_URL=http://192.168.1.100:5173
#
# Production example:
# VITE_PUBLIC_APP_URL=https://your-domain.com

VITE_PUBLIC_APP_URL=http://localhost:5173
